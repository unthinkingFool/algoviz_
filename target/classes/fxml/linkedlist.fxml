<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.dsa.visualizer.controllers.LinkedlistController"
            prefWidth="1200"
            prefHeight="780"
            style="-fx-background-color: #ECF0F1;">

    <center>
        <VBox spacing="10" style="-fx-background-color: #ECF0F1;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER" style="-fx-background-color: #2C3E50; -fx-padding: 12;">
                <Label text="Linked List Visualizer" textFill="white"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Insert Controls -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 5;">
                <Label text="Value:" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                <TextField fx:id="inputField" promptText="Enter value" prefWidth="80"
                           style="-fx-font-size: 12px;"/>
                <Label text="Index:" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                <TextField fx:id="indexField" promptText="e.g. 0" prefWidth="60"
                           style="-fx-font-size: 12px;"/>
                <Separator orientation="VERTICAL" prefHeight="30"/>
                <Button fx:id="btnInsertHead" text="Insert Head" onAction="#handleInsertHead"
                        style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-size: 11px;"
                        prefWidth="90" prefHeight="30"/>
                <Button fx:id="btnInsertTail" text="Insert Tail" onAction="#handleInsertTail"
                        style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-size: 11px;"
                        prefWidth="90" prefHeight="30"/>
                <Button fx:id="btnInsertAt" text="Insert at Index" onAction="#handleInsertAt"
                        style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-font-size: 11px;"
                        prefWidth="110" prefHeight="30"/>
            </HBox>

            <!-- Delete / Search / Utility Controls -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 5;">
                <Button fx:id="btnDeleteHead" text="Delete Head" onAction="#handleDeleteHead"
                        style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 11px;"
                        prefWidth="90" prefHeight="30"/>
                <Button fx:id="btnDeleteTail" text="Delete Tail" onAction="#handleDeleteTail"
                        style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 11px;"
                        prefWidth="90" prefHeight="30"/>
                <Button fx:id="btnDeleteAt" text="Delete at Index" onAction="#handleDeleteAt"
                        style="-fx-background-color: #C0392B; -fx-text-fill: white; -fx-font-size: 11px;"
                        prefWidth="115" prefHeight="30"/>
                <Separator orientation="VERTICAL" prefHeight="30"/>
                <Button fx:id="btnSearch" text="Search" onAction="#handleAnimatedSearch"
                        style="-fx-background-color: #8E44AD; -fx-text-fill: white; -fx-font-size: 11px;"
                        prefWidth="75" prefHeight="30"/>
                <Button fx:id="btnRandom" text="Random" onAction="#handleGenerateRandom"
                        style="-fx-background-color: #9B59B6; -fx-text-fill: white; -fx-font-size: 11px;"
                        prefWidth="75" prefHeight="30"/>
                <Button fx:id="btnClear" text="Clear" onAction="#handleClear"
                        style="-fx-background-color: #95A5A6; -fx-text-fill: white; -fx-font-size: 11px;"
                        prefWidth="65" prefHeight="30"/>
            </HBox>

            <!-- Status Bar -->
            <HBox spacing="15" alignment="CENTER_LEFT"
                  style="-fx-background-color: #34495E; -fx-padding: 8; -fx-background-radius: 5;">
                <Label fx:id="statusLabel" text="Ready" textFill="white"
                       style="-fx-font-size: 12px;" HBox.hgrow="ALWAYS"/>
                <Label fx:id="sizeLabel" text="Size: 0 / 15" textFill="white"
                       style="-fx-font-size: 12px;"/>
            </HBox>






            <!-- Visualization Pane with horizontal scroll -->
            <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                        fitToHeight="true" fitToWidth="false"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: white; -fx-border-color: #BDC3C7; -fx-border-width: 2;">
                <Pane fx:id="visualPane" style="-fx-background-color: white;"
                      prefWidth="1400" prefHeight="220"/>
            </ScrollPane>

            <!-- Legend -->
            <HBox spacing="25" alignment="CENTER"
                  style="-fx-background-color: white; -fx-padding: 8; -fx-background-radius: 5;">
                <HBox spacing="5" alignment="CENTER">
                    <Label text="■" style="-fx-font-size: 16px; -fx-text-fill: #3498DB;"/>
                    <Label text="Node Data" style="-fx-font-size: 11px;"/>
                </HBox>
                <HBox spacing="5" alignment="CENTER">
                    <Label text="■" style="-fx-font-size: 16px; -fx-text-fill: #F39C12;"/>
                    <Label text="Highlighted" style="-fx-font-size: 11px;"/>
                </HBox>
                <HBox spacing="5" alignment="CENTER">
                    <Label text="■" style="-fx-font-size: 16px; -fx-text-fill: #E74C3C;"/>
                    <Label text="NULL" style="-fx-font-size: 11px;"/>
                </HBox>
                <HBox spacing="5" alignment="CENTER">
                    <Label text="■" style="-fx-font-size: 16px; -fx-text-fill: #E67E22;"/>
                    <Label text="HEAD / TAIL" style="-fx-font-size: 11px;"/>
                </HBox>
            </HBox>

        </VBox>
    </center>

    <!-- Right Panel: Pseudocode + Time Complexity -->
    <right>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    prefWidth="265" style="-fx-background-color: #2C3E50; -fx-background: #2C3E50;">
            <VBox spacing="14" style="-fx-background-color: #2C3E50; -fx-padding: 15;">

                <Label text="Algorithm Info"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="" style="-fx-border-color: #4A6278; -fx-border-width: 0 0 1 0; -fx-pref-height: 1; -fx-max-width: Infinity;"/>

                <!-- Insert at Head -->
                <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label text="Insert at Head"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3498DB;"/>
                    <Label text="Pseudocode:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;"/>
                    <Label wrapText="true"
                           text="newNode = Node(value)&#10;newNode.next = head&#10;head = newNode"
                           style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';"/>
                    <Label text="Time Complexity:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;"/>
                    <Label text="Best/Worst: O(1)" style="-fx-font-size: 11px; -fx-text-fill: #2ECC71; -fx-font-family: 'Courier New';"/>
                    <Label text="Space:      O(1)" style="-fx-font-size: 11px; -fx-text-fill: #3498DB; -fx-font-family: 'Courier New';"/>
                </VBox>

                <!-- Insert at Tail -->
                <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label text=" Insert at Tail"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3498DB;"/>
                    <Label text="Pseudocode:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;"/>
                    <Label wrapText="true"
                           text="newNode = Node(value)&#10;if head == null:&#10;  head = newNode&#10;else:&#10;  cur = head&#10;  while cur.next != null:&#10;    cur = cur.next&#10;  cur.next = newNode"
                           style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';"/>
                    <Label text="Time Complexity:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;"/>
                    <Label text="Best:  O(1) (empty)" style="-fx-font-size: 11px; -fx-text-fill: #2ECC71; -fx-font-family: 'Courier New';"/>
                    <Label text="Worst: O(n)"         style="-fx-font-size: 11px; -fx-text-fill: #E74C3C; -fx-font-family: 'Courier New';"/>
                    <Label text="Space: O(1)"         style="-fx-font-size: 11px; -fx-text-fill: #3498DB; -fx-font-family: 'Courier New';"/>
                </VBox>

                <!-- Insert at Index -->
                <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label text=" Insert at Index"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3498DB;"/>
                    <Label text="Pseudocode:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;"/>
                    <Label wrapText="true"
                           text="cur = head&#10;walk to index - 1&#10;newNode.next = cur.next&#10;cur.next = newNode"
                           style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';"/>
                    <Label text="Time Complexity:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;"/>
                    <Label text="Best:  O(1)" style="-fx-font-size: 11px; -fx-text-fill: #2ECC71; -fx-font-family: 'Courier New';"/>
                    <Label text="Worst: O(n)" style="-fx-font-size: 11px; -fx-text-fill: #E74C3C; -fx-font-family: 'Courier New';"/>
                    <Label text="Space: O(1)" style="-fx-font-size: 11px; -fx-text-fill: #3498DB; -fx-font-family: 'Courier New';"/>
                </VBox>

                <!-- Delete -->
                <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label text=" Delete"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3498DB;"/>
                    <Label text="Pseudocode:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;"/>
                    <Label wrapText="true"
                           text="// Head:&#10;head = head.next&#10;&#10;// Tail / Index:&#10;cur = head&#10;walk to index - 1&#10;cur.next = cur.next.next"
                           style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';"/>
                    <Label text="Time Complexity:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;"/>
                    <Label text="Head:  O(1)" style="-fx-font-size: 11px; -fx-text-fill: #2ECC71; -fx-font-family: 'Courier New';"/>
                    <Label text="Other: O(n)" style="-fx-font-size: 11px; -fx-text-fill: #E74C3C; -fx-font-family: 'Courier New';"/>
                    <Label text="Space: O(1)" style="-fx-font-size: 11px; -fx-text-fill: #3498DB; -fx-font-family: 'Courier New';"/>
                </VBox>

                <!-- Search -->
                <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label text=" Search"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3498DB;"/>
                    <Label text="Pseudocode:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;"/>
                    <Label wrapText="true"
                           text="cur = head&#10;while cur != null:&#10;  if cur.value == target:&#10;    return cur&#10;  cur = cur.next&#10;return null"
                           style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';"/>
                    <Label text="Time Complexity:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;"/>
                    <Label text="Best:  O(1)" style="-fx-font-size: 11px; -fx-text-fill: #2ECC71; -fx-font-family: 'Courier New';"/>
                    <Label text="Worst: O(n)" style="-fx-font-size: 11px; -fx-text-fill: #E74C3C; -fx-font-family: 'Courier New';"/>
                    <Label text="Space: O(1)" style="-fx-font-size: 11px; -fx-text-fill: #3498DB; -fx-font-family: 'Courier New';"/>
                </VBox>



            </VBox>
        </ScrollPane>
    </right>

</BorderPane>
