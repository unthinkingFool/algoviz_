<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>



<BorderPane prefHeight="780" prefWidth="1200" style="-fx-background-color: #ECF0F1;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dsa.visualizer.controllers.HeapController">

    <center>
        <VBox spacing="10" style="-fx-background-color: #ECF0F1;">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>

            <!-- ── Title bar ── -->
            <HBox alignment="CENTER" style="-fx-background-color: #2C3E50; -fx-padding: 12;">
                <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Heap Visualizer" textFill="white" />
            </HBox>

            <!-- ══ NEW: Heap type selection row ══ -->
            <HBox alignment="CENTER" prefHeight="34.0" prefWidth="898.0" spacing="20" style="-fx-background-color: white; -fx-padding: 14; -fx-background-radius: 5; -fx-border-color: #BDC3C7; -fx-border-width: 1; -fx-border-radius: 5;">
                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Select Heap Type:" />
                <Button fx:id="btnMaxHeap" onAction="#selectMaxHeap" prefHeight="38" prefWidth="160" style="-fx-background-color: #BDC3C7; -fx-text-fill: #2C3E50; -fx-font-size: 13px; -fx-cursor: hand;" text="🔺  Max-Heap" />
                <Button fx:id="btnMinHeap" onAction="#selectMinHeap" prefHeight="38" prefWidth="160" style="-fx-background-color: #BDC3C7; -fx-text-fill: #2C3E50; -fx-font-size: 13px; -fx-cursor: hand;" text="🔻  Min-Heap" />
            </HBox>


            <!-- ══ operationPanel: hidden until a mode is chosen ══ -->
            <VBox fx:id="operationPanel" spacing="10">

                <!-- Row 1: insert / extract / peek / clear -->
                <HBox alignment="CENTER_LEFT" prefHeight="42.0" prefWidth="900.0" spacing="10" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 5;">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Value:" />
                    <TextField fx:id="insertField" prefWidth="80" promptText="Enter value" style="-fx-font-size: 12px;" />
                    <Button fx:id="btnInsert" onAction="#handleInsert" prefHeight="30" prefWidth="70" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-size: 11px;" text="Insert" />
                    <Button fx:id="btnExtractMax" onAction="#handleExtractMax" prefHeight="30" prefWidth="100" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 11px;" text="Extract Max" />
                    <Button fx:id="btnPeekMax" onAction="#handlePeekMax" prefHeight="30" prefWidth="80" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-size: 11px;" text="Peek Max" />

                    <Separator orientation="VERTICAL" prefHeight="30" />

                    <!-- NEW: Random button -->
                    <Button fx:id="btnRandom" onAction="#handleRandom" prefHeight="30" prefWidth="120" style="-fx-background-color: #8E44AD; -fx-text-fill: white; -fx-font-size: 11px;" text=" Random" />

                    <Separator orientation="VERTICAL" prefHeight="30" />
                    <Button fx:id="btnClear" onAction="#handleClear" prefHeight="30" prefWidth="70" style="-fx-background-color: #95A5A6; -fx-text-fill: white; -fx-font-size: 11px;" text="Clear" />
                </HBox>

                <!-- Row 2: heap sort / build from array -->
                <HBox alignment="CENTER_LEFT" prefHeight="27.0" prefWidth="911.0" spacing="10" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 5;">
                    <Button fx:id="btnHeapSort" onAction="#handleHeapSort" prefHeight="30" prefWidth="120" style="-fx-background-color: #16A085; -fx-text-fill: white; -fx-font-size: 11px;" text="Heap Sort" />
                    <Separator orientation="VERTICAL" prefHeight="30" />
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Build from Array:" />
                    <TextField fx:id="buildArrayField" prefWidth="200" promptText="e.g. 3, 10, 5, 1, 8, 7" style="-fx-font-size: 12px;" />
                    <Button fx:id="btnBuildHeap" onAction="#handleBuildHeap" prefHeight="30" prefWidth="90" style="-fx-background-color: #9B59B6; -fx-text-fill: white; -fx-font-size: 11px;" text="Build Heap" />
                </HBox>

                <!-- Status bar -->
                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #34495E; -fx-padding: 8; -fx-background-radius: 5;">
                    <Label fx:id="statusLabel" style="-fx-font-size: 12px;" text="Ready" textFill="white" HBox.hgrow="ALWAYS" />
                    <Label fx:id="sizeLabel" style="-fx-font-size: 12px;" text="Size: 0" textFill="white" />
                    <Label fx:id="logLabel" style="-fx-font-size: 12px;" text="" textFill="#F39C12" />
                </HBox>

                <!-- Tree pane -->
                <ScrollPane fitToHeight="false" fitToWidth="false" hbarPolicy="AS_NEEDED" style="-fx-background-color: white; -fx-border-color: #BDC3C7; -fx-border-width: 2;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                    <Pane fx:id="treePane" prefHeight="415.0" prefWidth="1394.0" style="-fx-background-color: white;" />
                </ScrollPane>

                <!-- Array header -->

                <!-- Array pane -->
                <Pane fx:id="arrayPane" prefHeight="172.0" prefWidth="925.0" style="-fx-background-color: white; -fx-border-color: #BDC3C7; -fx-border-width: 1;" />

                <!-- Legend -->
                <HBox alignment="CENTER" prefHeight="26.0" prefWidth="861.0" spacing="25" style="-fx-background-color: white; -fx-padding: 8; -fx-background-radius: 5;">
                    <HBox alignment="CENTER" spacing="5">
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #E67E22;" text="●" />
                        <Label style="-fx-font-size: 11px;" text="Max Root" />
                    </HBox>
                    <HBox alignment="CENTER" spacing="5">
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #1ABC9C;" text="●" />
                        <Label style="-fx-font-size: 11px;" text="Min Root" />
                    </HBox>
                    <HBox alignment="CENTER" spacing="5">
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #3498DB;" text="●" />
                        <Label style="-fx-font-size: 11px;" text="Node" />
                    </HBox>
                    <HBox alignment="CENTER" spacing="5">
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #F1C40F;" text="●" />
                        <Label style="-fx-font-size: 11px;" text="Comparing" />
                    </HBox>
                    <HBox alignment="CENTER" spacing="5">
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #E74C3C;" text="●" />
                        <Label style="-fx-font-size: 11px;" text="Swapping" />
                    </HBox>
                    <HBox alignment="CENTER" spacing="5">
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #9B59B6;" text="●" />
                        <Label style="-fx-font-size: 11px;" text="Highlighted" />
                    </HBox>
                    <HBox alignment="CENTER" spacing="5">
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #2ECC71;" text="●" />
                        <Label style="-fx-font-size: 11px;" text="Sorted" />
                    </HBox>
                </HBox>

            </VBox>
            <!-- end operationPanel -->

        </VBox>
    </center>

    <right>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefWidth="265" style="-fx-background-color: #2C3E50; -fx-background: #2C3E50;" vbarPolicy="AS_NEEDED">
            <VBox spacing="14" style="-fx-background-color: #2C3E50; -fx-padding: 15;">

                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" text="Algorithm Info" />
                <Label style="-fx-border-color: #4A6278; -fx-border-width: 0 0 1 0;                               -fx-pref-height: 1; -fx-max-width: Infinity;" text="" />

                <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #27AE60;" text=" Insert" />
                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;" text="Pseudocode:" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';" text="insert(val):&#10;  heap.append(val)&#10;  i = size - 1&#10;  while i &gt; 0:&#10;    p = (i-1) / 2&#10;    if priority(heap[i], heap[p]):&#10;      swap(i, p)&#10;      i = p&#10;    else: break" wrapText="true" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #F39C12; -fx-font-family: 'Courier New';" text="Time: O(log n) | Space: O(1)" />
                </VBox>

                <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #E74C3C;" text=" Extract Root" />
                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;" text="Pseudocode:" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';" text="extractRoot():&#10;  root = heap[0]&#10;  heap[0] = heap[last]&#10;  heap.removeLast()&#10;  heapifyDown(0)&#10;&#10;heapifyDown(i):&#10;  target = i&#10;  l=2i+1 ; r=2i+2&#10;  check l, r by priority&#10;  if target != i:&#10;    swap; recurse" wrapText="true" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #F39C12; -fx-font-family: 'Courier New';" text="Time: O(log n) | Space: O(1)" />
                </VBox>

                <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #9B59B6;" text="Build Heap" />
                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;" text="Pseudocode:" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';" text="buildHeap(arr):&#10;  heap = arr&#10;  for i = n/2-1 to 0:&#10;    heapifyDown(i)" wrapText="true" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #2ECC71; -fx-font-family: 'Courier New';" text="Time: O(n) | Space: O(1)" />
                </VBox>

                <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #16A085;" text=" Heap Sort" />
                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #BDC3C7;" text="Pseudocode:" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';" text="heapSort():&#10;  buildHeap(arr)&#10;  for i = n-1 to 1:&#10;    swap(arr[0], arr[i])&#10;    heapifyDown(i, 0)" wrapText="true" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #F39C12; -fx-font-family: 'Courier New';" text="Time:  O(n log n)" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #3498DB; -fx-font-family: 'Courier New';" text="Space: O(1)" />
                </VBox>

                <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #F39C12;" text=" All Complexities" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';" text="Insert:       O(log n)" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';" text="Extract Root: O(log n)" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';" text="Peek Root:    O(1)" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #2ECC71; -fx-font-family: 'Courier New';" text="Build Heap:   O(n)" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1; -fx-font-family: 'Courier New';" text="Heap Sort:    O(n log n)" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #3498DB; -fx-font-family: 'Courier New';" text="Space:        O(1)" />
                </VBox>

                <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3498DB;" text=" Heap Property" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #ECF0F1;" text="Max-Heap: every parent ≥ children. Max at index 0.&#10;Min-Heap: every parent ≤ children. Min at index 0." wrapText="true" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #BDC3C7; -fx-font-family: 'Courier New';" text="Parent of i: (i-1)/2" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #BDC3C7; -fx-font-family: 'Courier New';" text="Left child:  2*i + 1" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #BDC3C7; -fx-font-family: 'Courier New';" text="Right child: 2*i + 2" />
                </VBox>

            </VBox>
        </ScrollPane>
    </right>

</BorderPane>
